apiVersion: v1
kind: Pod
metadata:
  name: nginx-proxy
  namespace: kube-system
  labels:
    addonmanager.kubernetes.io/mode: Reconcile
    k8s-app: kube-nginx
  annotations:
    nginx-cfg-checksum: "{{ nginx_stat.stat.checksum }}"
spec:
  hostNetwork: true
  dnsPolicy: ClusterFirstWithHostNet
  nodeSelector:
    kubernetes.io/os: linux
  priorityClassName: system-node-critical
  containers:
  - name: nginx-proxy
    image: {{ kubernetes_loadbalancer_nginx_image_repo }}:{{ kubernetes_loadbalancer_nginx_image_tag }}
    imagePullPolicy: IfNotPresent
    resources:
      requests:
        cpu: {{ kubernetes_loadbalancer_apiserver_cpu }}
        memory: {{ kubernetes_loadbalancer_apiserver_memory }}
      limits:
        cpu: {{ kubernetes_loadbalancer_apiserver_cpu }}
        memory: {{ kubernetes_loadbalancer_apiserver_memory }}
    {% if kubernetes_loadbalancer_apiserver_healthcheck_port is defined -%}
    livenessProbe:
      httpGet:
        path: /healthz
        port: {{ kubernetes_loadbalancer_apiserver_healthcheck_port }}
    readinessProbe:
      httpGet:
        path: /healthz
        port: {{ kubernetes_loadbalancer_apiserver_healthcheck_port }}
    {% endif -%}
    volumeMounts:
    - mountPath: /etc/nginx
      name: etc-nginx
      readOnly: true
  volumes:
  - name: etc-nginx
    hostPath:
      path: {{ kubernetes_loadbalancer_nginx_config_dir }}