---
apiVersion: operator.tigera.io/v1
kind: Installation
metadata:
  name: default
spec:
  registry: "{{ kubernetes_calico_cni_image_repository }}"
  controlPlaneReplicas: {{ kubernetes_calico_controlplane_replicas }}
  controlPlaneTolerations:
    - operator: Exists

  typhaDeployment:
    spec:
      template:
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                - matchExpressions:
                  - key: node-role.kubernetes.io/{{ kubernetes_calico_controlplane_nodeselector }}
                    operator: Exists
            podAntiAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
              - labelSelector:
                  matchLabels:
                    k8s-app: calico-typha
                topologyKey: kubernetes.io/hostname

  calicoKubeControllersDeployment:
    spec:
      template:
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                - matchExpressions:
                  - key: node-role.kubernetes.io/{{ kubernetes_calico_controlplane_nodeselector }}
                    operator: Exists
            podAntiAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
              - labelSelector:
                  matchLabels:
                    k8s-app: calico-kube-controllers
                topologyKey: kubernetes.io/hostname

  # Configures Calico networking.
  calicoNetwork:
    linuxDataplane: "{{ kubernetes_calico_dataplane_type }}"
    ipPools:
    - name: default-ipv4-ippool
      blockSize: 26
      cidr: "{{ kubernetes_pod_cidr }}"
      encapsulation: "{{ kubernetes_calico_encapulation_type }}"
      natOutgoing: Enabled
      nodeSelector: all()

{% if kubernetes_calico_dataplane_type == "BPF" %}
---
# This section configures the Kubernetes services endpoint.
kind: ConfigMap
apiVersion: v1
metadata:
  name: kubernetes-services-endpoint
  namespace: tigera-operator
data:
  KUBERNETES_SERVICE_HOST: "{{ kubernetes_apiserver_ip }}"
  KUBERNETES_SERVICE_PORT: "{{ kubernetes_apiserver_port | default ("6443")}}"
{% endif %}


{% if kubernetes_calico_apiserver_enabled | default(false) | bool %}
---
# This section configures the Calico API server.
# For more information, see: https://docs.tigera.io/calico/latest/reference/installation/api#operator.tigera.io/v1.APIServer
apiVersion: operator.tigera.io/v1
kind: APIServer
metadata:
  name: default
spec:
  apiServerDeployment:
    spec:
      template:
        spec:
          affinity:
            nodeAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
                nodeSelectorTerms:
                - matchExpressions:
                  - key: node-role.kubernetes.io/{{ kubernetes_calico_controlplane_nodeselector }}
                    operator: Exists
            podAntiAffinity:
              requiredDuringSchedulingIgnoredDuringExecution:
              - labelSelector:
                  matchLabels:
                    k8s-app: calico-apiserver
                topologyKey: kubernetes.io/hostname
{% endif %}

{% if kubernetes_calico_observability_enabled | default(false) | bool %}
---
# Configures the Calico Goldmane flow aggregator.
apiVersion: operator.tigera.io/v1
kind: Goldmane
metadata:
  name: default
---
# Configures the Calico Whisker observability UI.
apiVersion: operator.tigera.io/v1
kind: Whisker
metadata:
  name: default
{% endif %}
